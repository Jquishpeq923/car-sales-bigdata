{
    "name": "Proyecto Integrador JQ JG",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "charliermarsh.ruff",
                "ms-azuretools.vscode-containers"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/app/proyecto_integrador_jq_jg/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}"
            }
        }
    },
    "postCreateCommand": "echo 'source /app/proyecto_integrador_jq_jg/bin/activate' >> ~/.bashrc"
}